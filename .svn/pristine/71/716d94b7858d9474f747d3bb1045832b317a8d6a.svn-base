        assertEqualsNoSpaces(expected, augmentedLogicSchema.getConstraintByNumber(4009).toString());
        expected = "@4010 :- LINEITEM_PARTKEY(L, P), not(del_LINEITEM_PARTKEY(L, P)), ins_LINEITEM_SUPPKEY(LI, S), SUPPLIER_NATIONKEY(S, N), not(del_SUPPLIER_NATIONKEY(S, N)), del_Aux2(P, N)";
        assertEqualsNoSpaces(expected, augmentedLogicSchema.getConstraintByNumber(4010).toString());
        expected = "@4011 :- LINEITEM_PARTKEY(L, P), not(del_LINEITEM_PARTKEY(L, P)), ins_LINEITEM_SUPPKEY(LI, S), SUPPLIER_NATIONKEY(S, N), not(del_SUPPLIER_NATIONKEY(S, N)), not(Aux2(P, N)), not(ins_Aux2(P, N))";
        assertEqualsNoSpaces(expected, augmentedLogicSchema.getConstraintByNumber(4011).toString());
        expected = "@4012 :- LINEITEM_PARTKEY(L, P), not(del_LINEITEM_PARTKEY(L, P)), LINEITEM_SUPPKEY(LI, S), not(del_LINEITEM_SUPPKEY(LI, S)), ins_SUPPLIER_NATIONKEY(S, N), del_Aux2(P, N)";
        assertEqualsNoSpaces(expected, augmentedLogicSchema.getConstraintByNumber(4012).toString());
        expected = "@4013 :- LINEITEM_PARTKEY(L, P), not(del_LINEITEM_PARTKEY(L, P)), LINEITEM_SUPPKEY(LI, S), not(del_LINEITEM_SUPPKEY(LI, S)), ins_SUPPLIER_NATIONKEY(S, N), not(Aux2(P, N)), not(ins_Aux2(P, N))";
        assertEqualsNoSpaces(expected, augmentedLogicSchema.getConstraintByNumber(4013).toString());
        expected = "@4014 :- LINEITEM_PARTKEY(L, P), not(del_LINEITEM_PARTKEY(L, P)), LINEITEM_SUPPKEY(LI, S), not(del_LINEITEM_SUPPKEY(LI, S)), SUPPLIER_NATIONKEY(S, N), not(del_SUPPLIER_NATIONKEY(S, N)), del_Aux2(P, N)";
        assertEqualsNoSpaces(expected, augmentedLogicSchema.getConstraintByNumber(4014).toString());
    
        int numberOfRules = augmentedLogicSchema.getAllConstraints().size();
        assertEquals(56, numberOfRules);
