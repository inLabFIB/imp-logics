        assertEqualsNoSpaces(expected, augmentedLogicSchema.getConstraintByNumber(3014).toString());
        expected = "@3015 :- ins_LINEITEM_SUPPKEY(LI, S), LINEITEM_ORDERKEY(LI, O), not(del_LINEITEM_ORDERKEY(LI, O)), ORDER_CUSTOMER(O, C), not(del_ORDER_CUSTOMER(O, C)), SUPPLIER_NAME(S, N), not(del_SUPPLIER_NAME(S, N)), CUSTOMER_NAME(C, N), not(del_CUSTOMER_NAME(C, N))";
