package edu.upc.mpi.logicschema;

/**
 * Simple implementation of a logic predicate abstract class
 * 
 * @author Xavier Oriol
 */
public class PredicateImpl extends Predicate{
    private final int arity;

    public PredicateImpl(String name, int arity){
        super(name);
        assert arity >= 0:"Arity cannot be negative";
        this.arity = arity;
    }

    @Override
    public int getArity() {
        return arity;
    }

    @Override
    protected boolean equalsSpecific(Predicate p) {
        return (p instanceof PredicateImpl);
    }

    @Override
    protected int hashCodeSpecific() {
        return new Integer(arity).hashCode();
    }
}
